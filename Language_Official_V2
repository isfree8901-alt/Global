def style_summary_by_role(df: pd.DataFrame):
    def apply_row_style(row):
        role = clean_text(row.get("대상유형", ""))
        if role == "임원":
            bg = "#FEF3C7"
        elif role == "직책자":
            bg = "#DBEAFE"
        elif role == "비직책자":
            bg = "#DCFCE7"
        else:
            bg = "#F9FAFB"
        return [f"background-color: {bg};" for _ in row.index]
    return df.style.apply(apply_row_style, axis=1)


def build_course_role_kpi_df(df: pd.DataFrame, result_col: str) -> pd.DataFrame:
    if df is None or df.empty:
        return pd.DataFrame(columns=["신청과정", "대상유형", "총신청", "선발", "선정비율(%)", "선발기준", "초과여부"])
    temp = ensure_columns(df.copy(), ["신청과정", "대상유형", result_col])
    temp["신청과정"] = temp["신청과정"].fillna("").astype(str).str.strip()
    temp["대상유형"] = temp["대상유형"].fillna("").astype(str).str.strip().replace("", "미확인")
    rows = []
    for (course, role), grp in temp.groupby(["신청과정", "대상유형"], dropna=False):
        total = len(grp)
        selected = int(grp[result_col].fillna("").astype(str).eq("선발").sum())
        threshold = 30 if (course in ["민병철유폰", "스픽"] and role == "직책자") else None
        rows.append({
            "신청과정": course,
            "대상유형": role,
            "총신청": total,
            "선발": selected,
            "선정비율(%)": round((selected / total) * 100, 1) if total else 0.0,
            "선발기준": threshold if threshold is not None else "",
            "초과여부": "초과" if threshold is not None and selected > threshold else ("정상" if threshold is not None else ""),
        })
    return pd.DataFrame(rows).sort_values(by=["신청과정", "대상유형"]).reset_index(drop=True)


