def filter_result_df(df: pd.DataFrame, selected_course: str, selected_status: str, selected_risk: str, search_text: str) -> pd.DataFrame:
    result = df.copy()
    if result.empty:
        return result
    if selected_course != "전체":
        result = result[result["신청과정"] == selected_course].copy()
    if selected_status != "전체":
        result = result[result["수동최종결과"] == selected_status].copy()
    if selected_risk != "전체":
        if selected_risk == "리스크 있음":
            result = result[result["리스크유형"].fillna("").astype(str).str.strip() != ""].copy()
        else:
            result = result[result["리스크유형"].fillna("").astype(str).str.contains(selected_risk, na=False)].copy()
    if search_text.strip():
        keyword = search_text.strip()
        result = result[
            result["사번"].fillna("").astype(str).str.contains(keyword, na=False)
            | result["성명"].fillna("").astype(str).str.contains(keyword, na=False)
            | result["조직명"].fillna("").astype(str).str.contains(keyword, na=False)
        ].copy()
    return result


def summarize_upload_quality(name: str, raw_df: pd.DataFrame, std_df: pd.DataFrame, required_cols: list[str]) -> dict:
    missing = [c for c in required_cols if c not in std_df.columns]
    rows = len(raw_df) if raw_df is not None else 0
    warnings = []
    if std_df is not None and not std_df.empty:
        if "사번" in std_df.columns:
            invalid_emp = int(std_df["사번"].fillna("").astype(str).str.len().lt(5).sum())
            if invalid_emp > 0:
                warnings.append(f"사번 이상 {invalid_emp}건")
        if "신청과정" in std_df.columns:
            other_count = int((std_df["신청과정"] == "기타").sum())
            if other_count > 0:
                warnings.append(f"과정 미분류 {other_count}건")
    return {
        "파일명": name,
        "업로드": "완료" if raw_df is not None and not raw_df.empty else "없음",
        "행수": rows,
        "필수컬럼": "정상" if not missing else f"누락 {len(missing)}개",
        "경고": " / ".join(warnings) if warnings else "-",
    }


def build_quality_issue_df(applicant_df: pd.DataFrame, hr_df: pd.DataFrame) -> pd.DataFrame:
    issues = []
    if applicant_df is None or applicant_df.empty:
        return pd.DataFrame(columns=["유형", "사번", "성명", "신청과정", "상세"])
    hr_emp_set = set(hr_df["사번"].dropna().astype(str)) if hr_df is not None and not hr_df.empty else set()
    for _, row in applicant_df.iterrows():
        emp = clean_text(row.get("사번", ""))
        name = clean_text(row.get("성명", ""))
        course = clean_text(row.get("신청과정", ""))
        ignore_time_parse = clean_text(row.get("신청시간파싱무시", "")) == "Y"

        if not emp or not (re.fullmatch(r"\d{5}", emp) or re.fullmatch(r"[ABCD]\d{4}", emp)):
            issues.append({"유형": "사번 형식 이상", "사번": emp, "성명": name, "신청과정": course, "상세": "허용 형식: 숫자 5자리 또는 A/B/C/D + 숫자 4자리"})
        if pd.isna(pd.to_datetime(row.get("신청시간"), errors="coerce")) and not ignore_time_parse:
            issues.append({"유형": "신청시간 파싱 실패", "사번": emp, "성명": name, "신청과정": course, "상세": "시작/완료 시간 포맷 확인 필요"})
        if course == "기타":
            issues.append({"유형": "과정 미분류", "사번": emp, "성명": name, "신청과정": clean_text(row.get("원본과정", "")), "상세": "과정명 alias 추가 필요"})
        if hr_emp_set and emp not in hr_emp_set:
            issues.append({"유형": "인사DB 미매칭", "사번": emp, "성명": name, "신청과정": course, "상세": "인사DB 사번 확인 필요"})
        if pd.to_numeric(row.get("중복신청건수"), errors="coerce") > 1:
