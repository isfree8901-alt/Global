def build_applicant_df(exec_df: pd.DataFrame, leader_df: pd.DataFrame, general_df: pd.DataFrame) -> pd.DataFrame:
    frames = [df.copy() for df in [exec_df, leader_df, general_df] if df is not None and not df.empty]
    if not frames:
        return pd.DataFrame()
    combined = pd.concat(frames, ignore_index=True)
    combined["사번"] = combined["사번"].apply(normalize_emp_no)
    if "사번매칭키" not in combined.columns:
        combined["사번매칭키"] = combined["사번"].apply(clean_text)
    combined["신청시간"] = safe_to_datetime(combined["신청시간"])
    combined["중복신청건수"] = combined.groupby(["사번매칭키", "신청과정"])["사번매칭키"].transform("size")
    combined = combined.sort_values(by=["신청시간", "사번매칭키", "사번"], ascending=[True, True, True]).copy()
    return combined.drop_duplicates(subset=["사번매칭키", "신청과정"], keep="first").copy()


def get_blacklist_hit_reason(emp_no: str, app_time: pd.Timestamp, blacklist_df: pd.DataFrame) -> str:
    if blacklist_df.empty or not emp_no or pd.isna(app_time):
        return ""
    emp_blacklist = blacklist_df[blacklist_df["사번"] == emp_no].copy()
    for _, row in emp_blacklist.iterrows():
        bl_date = row.get("정규화날짜", pd.NaT)
        if pd.notna(bl_date) and bl_date <= app_time <= (bl_date + relativedelta(months=6)):
            base_reason = clean_text(row.get("블랙리스트사유", "")) or "미수료"
            return f"{base_reason} 이력으로 해당월 기준 6개월간 제외"
    return ""


def build_prev_history_features(prev_history_df: pd.DataFrame) -> pd.DataFrame:
    base_columns = [
        "사번", "지난3차수정보", "지난3차수차수", "지난3차수합",
        "최근3차수선발횟수", "최근3차수신청횟수", "최근3차수동일과정횟수"
    ]
    if prev_history_df is None or prev_history_df.empty:
        return pd.DataFrame(columns=base_columns)
    df = prev_history_df.copy()
    df["차수"] = pd.to_numeric(df["차수"], errors="coerce")
    df = df.dropna(subset=["사번"]).copy()
    df = df.sort_values(by=["사번", "차수"], ascending=[True, False])
    rows = []
    for emp_no, grp in df.groupby("사번", sort=False):
        grp = grp.sort_values(by="차수", ascending=False).copy()
        top3_rows = grp.head(3).copy()

        unique_round_rows = []
        seen_rounds = set()
        for _, row in grp.iterrows():
            round_val = pd.to_numeric(row.get("차수"), errors="coerce")
            if pd.isna(round_val):
                continue
            round_num = int(round_val)
            if round_num in seen_rounds:
                continue
            seen_rounds.add(round_num)
            unique_round_rows.append(row.to_dict())
            if len(unique_round_rows) >= 3:
                break

        round_only = [str(int(r.get("차수"))) for r in unique_round_rows if pd.notna(pd.to_numeric(r.get("차수"), errors="coerce"))]
        parts = []
        for row in unique_round_rows:
            piece_items = []
            round_num = pd.to_numeric(row.get("차수"), errors="coerce")
            if pd.notna(round_num):
                piece_items.append(f"{int(round_num)}차")
            if clean_text(row.get("과정명", "")):
                piece_items.append(clean_text(row.get("과정명", "")))
            if clean_text(row.get("선정결과", "")):
                piece_items.append(clean_text(row.get("선정결과", "")))
            if piece_items:
                parts.append(" / ".join(piece_items))

        selected_count = int(top3_rows["선정결과"].fillna("").astype(str).eq("선발").sum())
        applied_count = int(top3_rows["신청여부"].fillna("").astype(str).str.upper().eq("Y").sum())
        same_course_count = int(top3_rows["과정명"].fillna("").astype(str).str.strip().ne("").sum())

        rows.append({
            "사번": emp_no,
            "지난3차수정보": " | ".join(parts),
            "지난3차수차수": ",".join(round_only),
            "지난3차수합": float(len(round_only)),
            "최근3차수선발횟수": selected_count,
            "최근3차수신청횟수": applied_count,
            "최근3차수동일과정횟수": same_course_count,
        })
    return pd.DataFrame(rows)


def calculate_priority_score(row: pd.Series) -> int:
    score = 0
    role_type = clean_text(row.get("대상유형", ""))
    gst_recent = pd.to_numeric(row.get("GST(최근)"), errors="coerce")
    gst_3year = pd.to_numeric(row.get("GST(3년)"), errors="coerce")
    work_location_type = clean_text(row.get("근무구분", ""))
    prev_selected = pd.to_numeric(row.get("최근3차수선발횟수"), errors="coerce")
    prev_hist_count = pd.to_numeric(row.get("지난3차수합"), errors="coerce")
    duplicate_count = pd.to_numeric(row.get("중복신청건수"), errors="coerce")

    if role_type == "임원":
        score += 100
    elif role_type == "직책자":
        score += 80
    else:
        score += 50

    if pd.notna(gst_3year) and gst_3year > 0:
        score += 20
    if pd.notna(gst_recent) and gst_recent > 0:
        score += int(gst_recent) * 5
    if work_location_type == "해외":
        score += 10
    if pd.notna(prev_hist_count) and prev_hist_count == 0:
        score += 10
    if pd.notna(prev_selected) and prev_selected >= 2:
        score -= 30
    if pd.notna(duplicate_count) and duplicate_count > 1:
        score -= 10
    return score


def build_validation_flags(row: pd.Series) -> tuple[bool, str]:
    reasons = []
    emp_no = clean_text(row.get("사번", ""))
    app_time = pd.to_datetime(row.get("신청시간"), errors="coerce")
    course = clean_text(row.get("신청과정", ""))
    gst_recent = pd.to_numeric(row.get("GST(최근)"), errors="coerce")
    gst_3year = pd.to_numeric(row.get("GST(3년)"), errors="coerce")
    role_type = clean_text(row.get("대상유형", ""))
    ignore_time_parse = clean_text(row.get("신청시간파싱무시", "")) == "Y"
    has_hr_match = any(clean_text(row.get(col, "")) for col in ["한글", "직위명", "직책명", "근무지명(JOB)", "조직명", "부문/본부"]) or pd.notna(gst_recent) or pd.notna(gst_3year)

    if not emp_no or not (re.fullmatch(r"\d{5}", emp_no) or re.fullmatch(r"[ABCD]\d{4}", emp_no)):
        reasons.append("사번 형식 이상")
    if clean_text(row.get("사번이상", "")) == "Y":
        reasons.append("사번 정규화 실패")
    if pd.isna(app_time) and not ignore_time_parse:
        reasons.append("신청시간 파싱 실패")
    if course == "기타":
        reasons.append("과정 미분류")
    if not has_hr_match:
        reasons.append("인사DB 미매칭")
    if (pd.notna(gst_recent) and not (0 <= gst_recent <= 10)) or (pd.notna(gst_3year) and not (0 <= gst_3year <= 10)):
        reasons.append("GST 값 이상")
    if clean_text(row.get("블랙리스트사유적중", "")):
        reasons.append("블랙리스트 대상")
    if pd.to_numeric(row.get("중복신청건수"), errors="coerce") > 1:
        reasons.append("중복 신청")
    if role_type == "비직책자" and clean_text(row.get("직위명", "")) == "" and clean_text(row.get("직책명", "")) == "":
        reasons.append("직위/직책 판정 확인 필요")

    return (len(reasons) > 0, " | ".join(reasons))


