def merge_manual_result(original_df: pd.DataFrame, edited_df: pd.DataFrame) -> pd.DataFrame:
    base_df = ensure_row_id(original_df.copy())
    edit_df = ensure_row_id(edited_df.copy())
    if edit_df.empty or "__row_id" not in edit_df.columns:
        return base_df
    edit_small = edit_df[[c for c in ["__row_id", "수동최종결과", "수동사유"] if c in edit_df.columns]].drop_duplicates(subset=["__row_id"], keep="last").copy()
    merged = base_df.merge(edit_small, on="__row_id", how="left", suffixes=("", "_edited"))
    if "수동최종결과_edited" in merged.columns:
        merged["수동최종결과"] = merged["수동최종결과_edited"].where(
            merged["수동최종결과_edited"].notna() & (merged["수동최종결과_edited"].astype(str).str.strip() != ""), merged["수동최종결과"]
        )
    if "수동사유_edited" in merged.columns:
        merged["수동사유"] = merged["수동사유_edited"].where(
            merged["수동사유_edited"].notna() & (merged["수동사유_edited"].astype(str).str.strip() != ""), merged["수동사유"]
        )
    merged = merged.drop(columns=["수동최종결과_edited", "수동사유_edited"], errors="ignore")
    merged["수동최종결과"] = merged["수동최종결과"].replace("", pd.NA).fillna(merged["최종결과"])
    merged["수동사유"] = merged["수동사유"].replace("", pd.NA).fillna(merged["최종사유"])
    return ensure_row_id(merged)


