def prepare_visualization_df(df: pd.DataFrame, default_result_col: str = "") -> pd.DataFrame:
    columns = [
        "사번", "성명", "신청과정", "신청시간", "고용구분명", "직급명", "조직명", "부문/본부",
        "대상유형", "근무지명(JOB)", "GST(최근)", "GST(3년)", "리스크유형",
        "최근3차수선발횟수", "최근3차수신청횟수", "지난3차수합", "최종결과", "수동최종결과"
    ]
    result = ensure_columns(df.copy(), columns)
    result["사번"] = result["사번"].apply(normalize_emp_no).astype(str)
    result["성명"] = result["성명"].fillna("").astype(str).str.strip().replace("", "미확인")
    for col in ["신청과정", "고용구분명", "직급명", "조직명", "부문/본부", "대상유형", "근무지명(JOB)", "리스크유형"]:
        result[col] = result[col].fillna("").astype(str).str.strip()
    result["신청과정"] = result["신청과정"].replace("", "미분류")
    result["고용구분명"] = result["고용구분명"].replace("", "미확인")
    result["직급명"] = result["직급명"].replace("", "미확인")
    result["조직명"] = result["조직명"].replace("", "미확인")
    result["부문/본부"] = result["부문/본부"].replace("", "미확인")
    result["대상유형"] = result["대상유형"].replace("", "미확인")
    result["신청시간"] = pd.to_datetime(result["신청시간"], errors="coerce")
    result["신청일"] = result["신청시간"].dt.strftime("%Y-%m-%d").fillna("미확인")
    result["신청시간대"] = result["신청시간"].dt.hour
    result["신청시간대"] = result["신청시간대"].where(result["신청시간대"].notna(), -1).astype(int)
    result["신청시간대라벨"] = result["신청시간대"].apply(lambda x: f"{x:02d}시" if x >= 0 else "미확인")
    result["근무구분"] = result["근무지명(JOB)"].apply(classify_work_location)
    result["GST(최근)"] = pd.to_numeric(result["GST(최근)"], errors="coerce")
    result["GST(3년)"] = pd.to_numeric(result["GST(3년)"], errors="coerce")
    result["최근3차수선발횟수"] = pd.to_numeric(result["최근3차수선발횟수"], errors="coerce").fillna(0).astype(int)
    result["최근3차수신청횟수"] = pd.to_numeric(result["최근3차수신청횟수"], errors="coerce").fillna(0).astype(int)
    result["지난3차수합"] = pd.to_numeric(result["지난3차수합"], errors="coerce").fillna(0).astype(int)

    if "수동최종결과" in result.columns and result["수동최종결과"].fillna("").astype(str).str.strip().ne("").any():
        result["시각화결과"] = result["수동최종결과"].fillna("").astype(str).str.strip()
    elif "최종결과" in result.columns and result["최종결과"].fillna("").astype(str).str.strip().ne("").any():
        result["시각화결과"] = result["최종결과"].fillna("").astype(str).str.strip()
    else:
        result["시각화결과"] = default_result_col if default_result_col else ""

    result["시각화결과"] = result["시각화결과"].replace("", "미확정")
    return result


def build_visualization_source(applicant_df: pd.DataFrame, hr_df: pd.DataFrame, result_df: pd.DataFrame | None = None) -> pd.DataFrame:
    if result_df is not None and not result_df.empty:
        return prepare_visualization_df(result_df.copy())

    if applicant_df is None or applicant_df.empty:
        return pd.DataFrame()

    hr_small_cols = ["사번", "고용구분명", "직급명", "조직명", "부문/본부", "직위명", "직책명", "근무지명(JOB)", "GST(최근)", "GST(3년)"]
    hr_small = ensure_columns(standardize_hr_df(hr_df if hr_df is not None else pd.DataFrame()), hr_small_cols)[hr_small_cols].drop_duplicates(subset=["사번"], keep="first")
    base = applicant_df.copy()
    base = ensure_row_id(base)
    base = base.merge(hr_small, on="사번", how="left")

    if "대상유형" not in base.columns:
        def _infer_role(row):
            _, role_type = get_role_priority(row.get("직위명", ""), row.get("직책명", ""))
            return role_type
        base["대상유형"] = base.apply(_infer_role, axis=1)

    prev_cols = [c for c in ["최근3차수선발횟수", "최근3차수신청횟수", "지난3차수합"] if c in base.columns]
    for c in ["최근3차수선발횟수", "최근3차수신청횟수", "지난3차수합"]:
        if c not in base.columns:
            base[c] = 0

    base["최종결과"] = ""
    base["수동최종결과"] = ""
    base["리스크유형"] = ""
    return prepare_visualization_df(base.copy())


