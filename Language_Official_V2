def extract_leader_hr_df(hr_df: pd.DataFrame) -> pd.DataFrame:
    if hr_df is None or hr_df.empty:
        return pd.DataFrame()

    temp = hr_df.copy()

    def classify_target_type(row):
        _, role_type = get_role_priority(row.get("직위명", ""), row.get("직책명", ""))
        return role_type

    temp["대상유형"] = temp.apply(classify_target_type, axis=1)
    leader_df = temp[temp["대상유형"] == "직책자"].copy()

    display_cols = [
        "사번", "한글", "직급명", "직위명", "직책명",
        "조직코드", "조직명", "부문/본부", "재직구분명", "직무명",
        "대륙(JOB)", "국가/도시(JOB)", "근무지명(JOB)",
        "내선번호", "휴대폰번호", "회사메일",
        "GST(최근)", "GST(3년)", "대상유형"
    ]

    for col in display_cols:
        if col not in leader_df.columns:
            leader_df[col] = ""

    leader_df = leader_df[display_cols].copy()
    leader_df["사번"] = leader_df["사번"].fillna("").astype(str)

    for gst_col in ["GST(최근)", "GST(3년)"]:
        if gst_col in leader_df.columns:
            leader_df[gst_col] = leader_df[gst_col].apply(
                lambda x: "" if pd.isna(x) or str(x).strip() == "" else int(float(x))
            )

    return leader_df


def ensure_columns(df: pd.DataFrame, columns: list[str]) -> pd.DataFrame:
    result = df.copy()
    for col in columns:
        if col not in result.columns:
            result[col] = ""
    return result


def make_row_id(df: pd.DataFrame) -> pd.Series:
    temp_time = pd.to_datetime(df["신청시간"], errors="coerce").dt.strftime("%Y-%m-%d %H:%M:%S").fillna("")
    return safe_str_series(df["사번"]) + "||" + safe_str_series(df["신청과정"]) + "||" + temp_time


def ensure_row_id(df: pd.DataFrame) -> pd.DataFrame:
    result = df.copy()
    if "__row_id" not in result.columns and all(c in result.columns for c in ["사번", "신청과정", "신청시간"]):
        result["__row_id"] = make_row_id(result)
    return result


def normalize_display_df(df: pd.DataFrame) -> pd.DataFrame:
    result = df.copy()
    if "사번" in result.columns:
        result["사번"] = result["사번"].apply(normalize_emp_no).astype(str)
    if "사번매칭키" in result.columns:
        result["사번매칭키"] = result["사번매칭키"].fillna("").astype(str)
    if "한글" in result.columns:
        if "성명" not in result.columns:
            result["성명"] = ""
        result["성명"] = result.apply(
            lambda x: clean_text(x.get("한글", "")) or clean_text(x.get("성명", "")) or "미확인",
            axis=1,
        )
    elif "성명" in result.columns:
        result["성명"] = safe_str_series(result["성명"])
    for gst_col in ["GST(최근)", "GST(3년)", " GST", "GST(3ys)"]:
        if gst_col in result.columns:
            result[gst_col] = result[gst_col].apply(format_gst_display)
    return result


def format_gst_display(value):
    if pd.isna(value) or clean_text(value) == "":
        return ""
    try:
        return str(int(float(value)))
    except Exception:
        return clean_text(value)


def load_upload_meta() -> dict:
    if UPLOAD_META_PATH.exists():
        try:
            return json.loads(UPLOAD_META_PATH.read_text(encoding="utf-8"))
        except Exception:
            return {}
    return {}


def save_upload_meta(meta: dict) -> None:
    UPLOAD_META_PATH.write_text(json.dumps(meta, ensure_ascii=False, indent=2), encoding="utf-8")


def save_uploaded_binary(uploaded_file, base_path: Path, file_key: str):
    if uploaded_file is None:
        return None
    for old_file in base_path.parent.glob(base_path.name + ".*"):
        try:
            old_file.unlink()
        except Exception:
            pass
    ext = Path(uploaded_file.name).suffix.lower()
    save_path = base_path.with_suffix(ext)
    uploaded_file.seek(0)
    save_path.write_bytes(uploaded_file.read())
    uploaded_file.seek(0)
    meta = load_upload_meta()
    meta[file_key] = {
        "original_name": uploaded_file.name,
        "saved_path": str(save_path),
        "ext": ext,
        "uploaded_at": dt.datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
    }
    save_upload_meta(meta)
    return save_path


def list_existing_saved_files(base_path: Path) -> list[Path]:
    existing_files = []
    for file_path in base_path.parent.glob(base_path.name + ".*"):
        try:
            if file_path.exists() and file_path.is_file():
                existing_files.append(file_path)
        except Exception:
            continue
    existing_files.sort(key=lambda p: p.stat().st_mtime, reverse=True)
    return existing_files


def load_saved_file(base_path: Path):
    matched_files = list_existing_saved_files(base_path)
    if not matched_files:
        return None, None
    file_path = matched_files[0]
    try:
        return file_path.read_bytes(), file_path.suffix.lower()
    except Exception:
        return None, None


def get_saved_file_info(base_path: Path, file_key: str):
    meta = load_upload_meta()
    info = meta.get(file_key, {})
    matched_files = list_existing_saved_files(base_path)
    if not matched_files:
        saved_path = clean_text(info.get("saved_path", ""))
        if saved_path:
            try:
                file_path = Path(saved_path)
                if file_path.exists() and file_path.is_file():
                    matched_files = [file_path]
            except Exception:
                matched_files = []
    if not matched_files:
        return None
    file_path = matched_files[0]
    try:
        fallback_uploaded_at = dt.datetime.fromtimestamp(file_path.stat().st_mtime).strftime("%Y-%m-%d %H:%M:%S")
    except Exception:
        fallback_uploaded_at = dt.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    return {
        "original_name": info.get("original_name", file_path.name),
        "saved_path": str(file_path),
        "ext": file_path.suffix.lower(),
        "uploaded_at": info.get("uploaded_at", fallback_uploaded_at),
    }


def format_relative_time(datetime_text: str) -> str:
    if not datetime_text:
        return ""
    try:
        uploaded_dt = dt.datetime.strptime(datetime_text, "%Y-%m-%d %H:%M:%S")
        diff = dt.datetime.now() - uploaded_dt
        sec = int(diff.total_seconds())
        if sec < 60:
            return f"{sec}초 전"
        if sec < 3600:
            return f"{sec // 60}분 전"
        if sec < 86400:
            return f"{sec // 3600}시간 전"
        return f"{sec // 86400}일 전"
    except Exception:
        return ""


def read_file_from_bytes(file_bytes: bytes, ext: str) -> pd.DataFrame:
    if ext == ".csv":
        try:
            return pd.read_csv(io.BytesIO(file_bytes), encoding="utf-8-sig", dtype=str)
        except Exception:
            return pd.read_csv(io.BytesIO(file_bytes), encoding="cp949", dtype=str)
    if ext in [".xlsx", ".xls"]:
        return pd.read_excel(io.BytesIO(file_bytes), engine="openpyxl", dtype=str)
    raise ValueError(f"지원하지 않는 파일 형식입니다: {ext}")


def read_uploaded_or_saved(uploaded_file, base_path: Path, file_key: str) -> pd.DataFrame:
    if uploaded_file is not None:
        save_uploaded_binary(uploaded_file, base_path, file_key)
        ext = Path(uploaded_file.name).suffix.lower()
        uploaded_file.seek(0)
        return read_file_from_bytes(uploaded_file.read(), ext)
    file_bytes, ext = load_saved_file(base_path)
    if file_bytes is not None:
        return read_file_from_bytes(file_bytes, ext)
    return pd.DataFrame()


def clear_saved_files():
    for base_path in [HR_SAVE_PATH, EXEC_SAVE_PATH, LEADER_SAVE_PATH, GENERAL_SAVE_PATH, BLACKLIST_SAVE_PATH, PREV_HISTORY_SAVE_PATH]:
        for file_path in base_path.parent.glob(base_path.name + ".*"):
            try:
                file_path.unlink()
            except Exception:
                pass
    for path in [UPLOAD_META_PATH, AUTO_RESULT_SAVE_PATH, MANUAL_RESULT_SAVE_PATH]:
        if path.exists():
            try:
                path.unlink()
            except Exception:
                pass


