def clean_text(value) -> str:
    if pd.isna(value):
        return ""
    return str(value).strip()


def normalize_column_token(value: str) -> str:
    text = clean_text(value)
    text = text.replace("\ufeff", "")
    text = re.sub(r"\s+", "", text)
    text = text.replace("(", "").replace(")", "")
    text = text.replace("/", "").replace("-", "")
    text = text.lower()
    return text


def safe_str_series(series: pd.Series) -> pd.Series:
    return series.fillna("").astype(str).str.strip()


def safe_to_datetime(series: pd.Series) -> pd.Series:
    return pd.to_datetime(series, errors="coerce")


def to_csv_bytes(df: pd.DataFrame) -> bytes:
    return df.to_csv(index=False, encoding="utf-8-sig").encode("utf-8-sig")


def normalize_emp_no(value) -> str:
    if pd.isna(value):
        return ""
    text = str(value).strip()
    text = text.replace(" ", " ").replace("​", "")
    text = text.replace("'", "").replace('"', "")
    text = text.replace(",", "")
    text = text.replace(".0", "")

    # Full-width digits / letters -> ASCII
    text = text.translate(str.maketrans(
        "０１２３４５６７８９ＡＢＣＤＥＦＧＨＩＪＫＬＭＮＯＰＱＲＳＴＵＶＷＸＹＺａｂｃｄｅｆｇｈｉｊｋｌｍｎｏｐｑｒｓｔｕｖｗｘｙｚ",
        "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"
    ))
    text = re.sub(r"[\s\-]+", "", text).upper()

    # Excel scientific notation fallback (e.g. 1.2345E+04)
    sci_match = re.fullmatch(r"\s*(\d+(?:\.\d+)?)\s*[eE]\s*\+?\s*(\d+)\s*", text)
    if sci_match:
        try:
            text = str(int(float(text)))
        except Exception:
            pass

    # 허용 형식 1) 숫자 5자리, 2) A/B/C/D + 숫자 4자리 (예: B1234)
    if re.fullmatch(r"\d{5}", text):
        return text
    if re.fullmatch(r"[ABCD]\d{4}", text):
        return text

    return ""


def infer_column(df: pd.DataFrame, candidate_keywords: list[str]):
    normalized_map = {col: normalize_column_token(col) for col in df.columns}
    items = list(normalized_map.items())
    for keyword in candidate_keywords:
        key = normalize_column_token(keyword)
        if not key:
            continue
        for col, norm_col in items:
            if key == norm_col:
                return col
        for col, norm_col in items:
            if key in norm_col or norm_col in key:
                return col
    return None


def parse_korean_date(date_str):
    if pd.isna(date_str) or clean_text(date_str) == "":
        return pd.NaT
    text = clean_text(date_str).replace(" ", "")
    text = re.sub(r"^(\d{2})년(\d{1,2})월$", r"20\1-\2-01", text)
    text = re.sub(r"^(\d{4})년(\d{1,2})월$", r"\1-\2-01", text)
    return pd.to_datetime(text, errors="coerce")


def get_simple_course(course_name: str) -> str:
    text = clean_text(course_name)
    if "민병철유폰" in text or "민병철" in text:
        return "민병철유폰"
    if "튜터링" in text:
        return "튜터링"
    if "링글" in text:
        return "링글"
    if "스픽" in text:
        return "스픽"
    return "기타"


def classify_work_location(location_text: str) -> str:
    return "해외" if clean_text(location_text) in OVERSEAS_LOCATIONS else "국내"


def get_role_priority(title, position):
    if clean_text(title) in EXECUTIVE_TITLES:
        return 0, "임원"
    if clean_text(position) in LEADER_ROLES:
        return 1, "직책자"
    return 2, "비직책자"


def get_priority_group_by_role(role_type: str, default_priority: int = 2) -> int:
    if role_type == "임원":
        return 0
    if role_type == "직책자":
        return 1
    return default_priority


def get_role_priority_text(role_type: str) -> str:
