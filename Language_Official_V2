def build_role_result_summary_df(df: pd.DataFrame, result_col: str) -> pd.DataFrame:
    summary_columns = ["신청과정", "정원", "선발인원", "잔여정원", "정원상태", "대상유형", result_col, "인원수"]
    if df is None or df.empty:
        return pd.DataFrame(columns=summary_columns)

    temp = df.copy()
    temp = ensure_columns(temp, ["신청과정", "대상유형", result_col])
    temp["신청과정"] = temp["신청과정"].fillna("").astype(str).str.strip()
    temp["대상유형"] = temp["대상유형"].fillna("").astype(str).str.strip().replace("", "미확인")
    temp[result_col] = temp[result_col].fillna("").astype(str).str.strip().replace("", "미확인")

    base = temp.groupby(["신청과정", "대상유형", result_col], dropna=False).size().reset_index(name="인원수")

    rows = []
    for _, row in base.iterrows():
        course = clean_text(row.get("신청과정", ""))
        capacity = int(COURSE_CAPACITY.get(course, 0)) if course in COURSE_CAPACITY else 0
        selected_count = int(temp[(temp["신청과정"] == course) & (temp[result_col] == "선발")].shape[0])
        remain = capacity - selected_count if capacity > 0 else ""
        if capacity > 0:
            status = "초과" if selected_count > capacity else ("마감" if selected_count == capacity else "여유")
        else:
            status = "정원미정"
        rows.append({
            "신청과정": course,
            "정원": capacity if capacity > 0 else "",
            "선발인원": selected_count if capacity > 0 else "",
            "잔여정원": remain if capacity > 0 else "",
            "정원상태": status,
            "대상유형": row.get("대상유형", "미확인"),
            result_col: row.get(result_col, "미확인"),
            "인원수": int(row.get("인원수", 0)),
        })

    return pd.DataFrame(rows)[summary_columns].sort_values(by=["신청과정", "대상유형", result_col]).reset_index(drop=True)


def build_capacity_status_df(df: pd.DataFrame, result_col: str) -> pd.DataFrame:
    columns = ["신청과정", "정원", "선발인원", "잔여정원", "상태"]
    if df is None or df.empty:
        return pd.DataFrame(columns=columns)

    rows = []
    for course in COURSE_CAPACITY.keys():
        course_df = df[df["신청과정"] == course].copy() if "신청과정" in df.columns else pd.DataFrame()
        capacity = int(COURSE_CAPACITY.get(course, 0))
        selected_count = int((course_df[result_col] == "선발").sum()) if not course_df.empty and result_col in course_df.columns else 0
        remain = capacity - selected_count
        status = "초과" if remain < 0 else ("마감" if remain == 0 else "여유")
        rows.append({
            "신청과정": course,
            "정원": capacity,
            "선발인원": selected_count,
            "잔여정원": remain,
            "상태": status,
        })
    return pd.DataFrame(rows)


