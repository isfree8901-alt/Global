        "근무지명(JOB)": row.get("근무지명(JOB)", ""),
        "사번이상": row.get("사번이상", ""),
        "신청시간파싱무시": row.get("신청시간파싱무시", ""),
    }))
    base["검증필요"] = validation_flag
    base["검증사유"] = validation_reason

    if clean_text(base.get("사번이상", "")) == "Y":
        first_status, first_reason, priority_group = "제외", "사번 형식 이상으로 자동 제외", 99
    elif blacklist_reason:
        first_status, first_reason, priority_group = "제외", blacklist_reason, 99
    elif course == "기타":
        first_status, first_reason, priority_group = "수동확인", "과정명을 분류하지 못했습니다.", 98
    elif validation_flag and "인사DB 미매칭" in validation_reason:
        first_status, first_reason, priority_group = "수동확인", "인사DB 매칭 실패", 97
    elif course == "민병철유폰":
        if role_type in ["임원", "직책자"]:
            first_status, first_reason, priority_group = "선발검토", f"{get_role_priority_text(role_type)} 자동 승인", get_priority_group_by_role(role_type)
        elif pd.notna(gst_3year) and gst_3year > 0:
            first_status, first_reason, priority_group = "선발검토", f"최근 3년 내 GST 성적 보유 / {get_role_priority_text(role_type)} 반영", get_priority_group_by_role(role_type, 2)
        else:
            first_status, first_reason, priority_group = "제외", "최근 3년 내 GST 성적 없음", 99
    elif course == "튜터링":
        if pd.notna(gst_3year) and gst_3year > 0:
            first_status, first_reason, priority_group = "선발검토", f"최근 3년 내 GST 성적 보유 / {get_role_priority_text(role_type)} 우선순위 반영", get_priority_group_by_role(role_type, 2)
        else:
            first_status, first_reason, priority_group = "제외", "최근 3년 내 GST 성적 없음", 99
    elif course == "링글":
        if role_type == "임원":
            first_status, first_reason, priority_group = "선발검토", f"{get_role_priority_text(role_type)} 자동 승인", get_priority_group_by_role(role_type)
        else:
            required_level = 5 if work_location_type == "해외" else 6
            if pd.notna(gst_3year) and gst_3year >= required_level:
                first_status, first_reason, priority_group = "선발검토", f"{work_location_type} 근무자 기준 최근 3년 GST 레벨 {required_level} 이상 충족 / {get_role_priority_text(role_type)} 우선순위 반영", get_priority_group_by_role(role_type, 2)
            elif pd.notna(gst_recent) and pd.isna(gst_3year):
                first_status, first_reason, priority_group = "제외", "최근 3년 내 유효 GST 성적 없음 (단, GST 성적 보유)", 99
            else:
                first_status, first_reason, priority_group = "제외", f"{work_location_type} 근무자 기준 최근 3년 GST 레벨 {required_level} 미달", 99
    elif course == "스픽":
        if role_type in ["임원", "직책자"]:
            first_status, first_reason, priority_group = "선발검토", f"{get_role_priority_text(role_type)} 자동 승인", get_priority_group_by_role(role_type)
        elif pd.notna(gst_3year) and gst_3year > 0:
            first_status, first_reason, priority_group = "선발검토", f"최근 3년 내 GST 성적 보유 / {get_role_priority_text(role_type)} 우선선발", get_priority_group_by_role(role_type, 2)
        elif pd.notna(gst_recent) and gst_recent > 0:
            first_status, first_reason, priority_group = "선발검토", f"GST 성적 보유 / {get_role_priority_text(role_type)} 우선순위 반영", get_priority_group_by_role(role_type, 3)
        else:
            first_status, first_reason, priority_group = "제외", "GST 성적 없음", 99
    else:
        first_status, first_reason, priority_group = "수동확인", "판정 규칙 미정", 98

    base["1차판정"] = first_status
    base["1차판정사유"] = first_reason
    base["선발우선그룹"] = priority_group
    base["우선순위점수"] = calculate_priority_score(pd.Series(base))
    return base


def run_selection_engine(hr_df, exec_df, leader_df, general_df, blacklist_df, prev_history_df):
    applicant_df = build_applicant_df(exec_df, leader_df, general_df)
    if applicant_df.empty:
        return pd.DataFrame()
    hr_df = standardize_hr_df(hr_df if hr_df is not None else pd.DataFrame())
    blacklist_df = standardize_blacklist_df(blacklist_df if blacklist_df is not None else pd.DataFrame())
    prev_features = build_prev_history_features(prev_history_df if prev_history_df is not None else pd.DataFrame())

    if "사번매칭키" not in applicant_df.columns:
        applicant_df["사번매칭키"] = applicant_df["사번"].apply(clean_text)
    if "사번매칭키" not in hr_df.columns:
        hr_df["사번매칭키"] = hr_df["사번"].apply(clean_text)

    merged = applicant_df.merge(hr_df, on="사번매칭키", how="left", suffixes=("", "_hr"))
    merged = merged.merge(prev_features, on="사번", how="left")
    merged["성명"] = merged.apply(lambda x: clean_text(x["성명"]) if clean_text(x.get("성명", "")) else clean_text(x.get("한글", "")), axis=1)
    merged["이메일"] = merged.apply(lambda x: clean_text(x["이메일"]) if clean_text(x.get("이메일", "")) else clean_text(x.get("회사메일", "")), axis=1)

    result_df = pd.DataFrame([evaluate_one_applicant(row, blacklist_df) for _, row in merged.iterrows()])
    if result_df.empty:
        return result_df

    result_df["최종결과"] = ""
    result_df["최종사유"] = ""
    result_df["리스크유형"] = ""

    for course_name, capacity in COURSE_CAPACITY.items():
        group = result_df[result_df["신청과정"] == course_name].copy()
        if group.empty:
            continue
        group = group.sort_values(
            by=["1차판정", "선발우선그룹", "우선순위점수", "신청시간", "사번"],
            ascending=[True, True, False, True, True],
        )
        selected_count = 0
        for idx, row in group.iterrows():
            first_status = clean_text(row.get("1차판정", ""))
            first_reason = clean_text(row.get("1차판정사유", ""))
            if first_status == "제외":
                result_df.at[idx, "최종결과"] = "제외"
                result_df.at[idx, "최종사유"] = first_reason
                continue
            if first_status == "수동확인":
                result_df.at[idx, "최종결과"] = "수동확인"
                result_df.at[idx, "최종사유"] = first_reason
                continue
            if selected_count < capacity:
                result_df.at[idx, "최종결과"] = "선발"
                result_df.at[idx, "최종사유"] = f"{first_reason} / 우선순위점수 {int(row.get('우선순위점수', 0))} / 정원 {capacity}명 이내"
                selected_count += 1
            else:
                result_df.at[idx, "최종결과"] = "후순위"
                result_df.at[idx, "최종사유"] = f"정원 초과로 후순위 / {first_reason} / 우선순위점수 {int(row.get('우선순위점수', 0))}"

        if len(group) > capacity and capacity > 0:
            boundary_rows = group.iloc[max(0, capacity - 2): min(len(group), capacity + 2)]
            result_df.loc[boundary_rows.index, "리스크유형"] = result_df.loc[boundary_rows.index, "리스크유형"].replace("", "정원 경계선")

    other_mask = ~result_df["신청과정"].isin(list(COURSE_CAPACITY.keys()))
    if other_mask.any():
        result_df.loc[other_mask, "최종결과"] = result_df.loc[other_mask, "1차판정"].replace("선발검토", "수동확인")
        result_df.loc[other_mask, "최종사유"] = result_df.loc[other_mask, "1차판정사유"]

    result_df.loc[result_df["검증필요"], "리스크유형"] = result_df.loc[result_df["검증필요"], "검증사유"]
    result_df["수동최종결과"] = result_df["최종결과"]
    result_df["수동사유"] = result_df["최종사유"]
    return ensure_row_id(result_df.sort_values(by=["신청과정", "신청시간", "사번"], ascending=[True, True, True]).reset_index(drop=True))


