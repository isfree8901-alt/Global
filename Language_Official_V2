def style_result_table(df: pd.DataFrame):
    def apply_row_style(row):
        status = clean_text(row.get("수동최종결과", row.get("최종결과", "")))
        if status == "선발":
            bg = BRAND["soft_green"]
        elif status == "후순위":
            bg = BRAND["soft_yellow"]
        elif status == "제외":
            bg = BRAND["soft_red"]
        elif status == "수동확인":
            bg = BRAND["soft_purple"]
        else:
            bg = "#FFFFFF"
        return [f"background-color: {bg};" for _ in row.index]
    return df.style.apply(apply_row_style, axis=1)


