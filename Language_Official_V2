        "최근3차수신청횟수": pd.to_numeric(row.get("최근3차수신청횟수"), errors="coerce"),
        "중복신청건수": pd.to_numeric(row.get("중복신청건수"), errors="coerce"),
        "블랙리스트사유적중": blacklist_reason,
