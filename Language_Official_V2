        "사번이상": clean_text(row.get("사번이상", "")),
    }

    base["선발우선그룹"] = get_priority_group_by_role(role_type)
    validation_flag, validation_reason = build_validation_flags(pd.Series(base | {
        "한글": row.get("한글", ""),
        "직위명": row.get("직위명", ""),
        "직책명": row.get("직책명", ""),
