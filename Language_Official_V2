def _standardize_applicant_common(df: pd.DataFrame, applicant_type: str, form_kind: str) -> pd.DataFrame:
    result = df.copy()
    rename_map = {
        infer_column(result, [
            "사번",
            "사번을입력해주세요",
            "사번을 입력해주세요",
            "사번을입력해주세요(정확히입력해주세요)",
            "사번을입력해주세요.(정확히입력해주세요)",
            "임직원번호",
            "직원번호",
        ]): "사번",
        infer_column(result, [
            "성명",
            "이름",
            "이름을입력해주세요",
            "이름을입력해주세요(정확히입력해주세요)",
            "이름을입력해주세요.(정확히입력해주세요)",
        ]): "성명",
        infer_column(result, ["신청하려는과정을선택해주세요"]): "원본과정",
        infer_column(result, ["시작시간"]): "시작시간",
        infer_column(result, ["완료시간"]): "완료시간",
        infer_column(result, ["전자메일"]): "이메일",
        infer_column(result, ["신청하신과정에탈락이되어다른과정으로대체될경우지원하시겠습니까?"]): "대체지원여부",
        infer_column(result, ["신청자가많아신청과정입과가어려울시다음으로선호하는과정을선택해주세요."]): "차순위희망과정",
        infer_column(result, ["현재근무지역을선택해주세요."]): "현재근무지역",
        infer_column(result, ["가장최근GST응시일이언제인가요?(YYYY-MM-DD)"]): "GST응시일(폼)",
        infer_column(result, ["교육업체에서연락시수신가능한전화번호를작성해주세요.(국제전화번호가능)"]): "연락처",
    }
    rename_map = {k: v for k, v in rename_map.items() if k}
    result = result.rename(columns=rename_map)
    result = ensure_columns(result, ["사번", "성명", "원본과정", "시작시간", "완료시간", "이메일", "대체지원여부", "차순위희망과정", "현재근무지역", "GST응시일(폼)", "연락처"])
    result["신청구분"] = applicant_type
    result["신청원본유형"] = form_kind
    result["사번원본"] = result["사번"].copy()
    result["사번"] = result["사번"].apply(normalize_emp_no)
    result["사번매칭키"] = result["사번"].apply(clean_text)
    result["사번이상"] = result.apply(
        lambda x: "Y" if clean_text(x.get("사번", "")) == "" else "",
        axis=1,
    )
    result["성명"] = safe_str_series(result["성명"])
    result["원본과정"] = safe_str_series(result["원본과정"])
    result["신청과정"] = result["원본과정"].apply(get_simple_course)

    start_time = safe_to_datetime(result["시작시간"])
    end_time = safe_to_datetime(result["완료시간"])

    # 임원 신청 DB는 시작/완료 시간 값의 신뢰도가 낮아서
    # 파싱 실패를 데이터 오류로 보지 않고 무시합니다.
    ignore_time_parse = (applicant_type == "임원신청")
    result["신청시간파싱무시"] = "Y" if ignore_time_parse else ""

    if ignore_time_parse:
        # 파싱되면 사용하고, 실패하면 빈값으로 둡니다.
        # 이후 검증 로직에서 임원신청은 시간 파싱 실패를 리스크로 보지 않도록 처리합니다.
        result["신청시간"] = start_time.where(start_time.notna(), end_time)
    else:
        result["신청시간"] = start_time.where(start_time.notna(), end_time)

    for col in ["이메일", "대체지원여부", "차순위희망과정", "현재근무지역", "GST응시일(폼)", "연락처"]:
        result[col] = safe_str_series(result[col])
    return result


